{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">

    {# Filter bar #}
    <div class="panel panel-default">
      <div class="panel-body">
        <form method="get" action="{{ index_url }}" class="form-inline">
          <input type="hidden" name="route" value="extension/payment/cardlink_transactions">
          <div class="input-group" style="margin-right:8px;">
            <span class="input-group-addon">{{ text_filter }}</span>
            <input type="number" name="order_id" value="{{ filter_order_id }}" class="form-control" placeholder="Order ID" style="width:140px;">
          </div>
          <button type="submit" class="btn btn-primary"><i class="fa fa-search"></i> {{ text_filter_btn }}</button>
          {% if filter_order_id %}
            <a href="{{ index_url }}" class="btn btn-default" style="margin-left:6px;"><i class="fa fa-times"></i> {{ text_reset }}</a>
          {% endif %}
        </form>
      </div>
    </div>

    {# Transactions table #}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-credit-card"></i> {{ text_list }}
          {% if total %}<span class="badge">{{ total }}</span>{% endif %}
        </h3>
      </div>
      <div class="panel-body">
        {% if transactions %}
          <div class="table-responsive">
            <table class="table table-bordered table-hover" id="cardlink-tx-table">
              <thead>
                <tr>
                  <th>{{ column_order_id }}</th>
                  <th>{{ column_cardlink_id }}</th>
                  <th>{{ column_tx_id }}</th>
                  <th>{{ column_payment_ref }}</th>
                  <th>{{ column_status }}</th>
                  <th>{{ column_amount }}</th>
                  <th>{{ column_pay_method }}</th>
                  <th>{{ column_date }}</th>
                  <th>{{ column_actions }}</th>
                </tr>
              </thead>
              <tbody>
                {% for tx in transactions %}
                  <tr data-tx-id="{{ tx.id }}" data-amount="{{ tx.amount }}" data-currency="{{ tx.currency }}">
                    <td><a href="#" target="_blank">#{{ tx.order_id }}</a></td>
                    <td><code style="font-size:11px;">{{ tx.cardlink_order_id }}</code></td>
                    <td>{{ tx.tx_id }}</td>
                    <td>{{ tx.payment_ref }}</td>
                    <td>
                      <span class="label label-{{ tx.status == 'CAPTURED' ? 'success' : (tx.status in ['AUTHORIZED','PARTIALLY_CAPTURED'] ? 'warning' : (tx.status in ['REFUNDED','PARTIALLY_REFUNDED'] ? 'info' : (tx.status == 'CANCELED' ? 'danger' : 'default'))) }}">
                        {{ tx.status }}
                      </span>
                    </td>
                    <td>{{ tx.amount }} {{ tx.currency }}</td>
                    <td>{{ tx.pay_method }}</td>
                    <td>{{ tx.created_at }}</td>
                    <td>

                      {% if xml_api_enabled %}

                        {# AUTHORIZED / PARTIALLY_CAPTURED: Capture remaining + Partial Capture + Void #}
                        {% if tx.status in ['AUTHORIZED', 'PARTIALLY_CAPTURED'] %}
                          <button type="button" class="btn btn-success btn-xs btn-capture"
                            data-tx="{{ tx.id }}">
                            <i class="fa fa-check"></i> {{ button_capture }}
                            ({{ tx.remaining_capture }} {{ tx.currency }})
                          </button>
                          <button type="button" class="btn btn-warning btn-xs btn-partial-capture"
                            data-tx="{{ tx.id }}" data-max="{{ tx.remaining_capture }}">
                            <i class="fa fa-pencil"></i> {{ button_partial_capture }}
                          </button>
                          <button type="button" class="btn btn-danger btn-xs btn-void"
                            data-tx="{{ tx.id }}">
                            <i class="fa fa-ban"></i> {{ button_void }}
                          </button>

                          {# Partial capture amount input #}
                          <div class="partial-form partial-capture-form-{{ tx.id }}" style="display:none;margin-top:6px;">
                            <div class="input-group input-group-sm">
                              <input type="number" step="0.01" min="0.01" max="{{ tx.remaining_capture }}"
                                class="form-control partial-amount" placeholder="{{ text_enter_amount }}" style="width:110px;">
                              <span class="input-group-btn">
                                <button type="button" class="btn btn-warning btn-sm btn-partial-capture-confirm"
                                  data-tx="{{ tx.id }}">{{ button_confirm }}</button>
                                <button type="button" class="btn btn-default btn-sm btn-partial-cancel"
                                  data-target=".partial-capture-form-{{ tx.id }}">{{ button_cancel }}</button>
                              </span>
                            </div>
                          </div>
                        {% endif %}

                        {# CAPTURED same-day: Void only #}
                        {% if tx.status == 'CAPTURED' and tx.is_today %}
                          <button type="button" class="btn btn-danger btn-xs btn-void"
                            data-tx="{{ tx.id }}" data-confirm="void-captured">
                            <i class="fa fa-ban"></i> {{ button_void }}
                          </button>
                        {% endif %}

                        {# CAPTURED next-day OR PARTIALLY_REFUNDED: Full Refund + Partial Refund #}
                        {% if (tx.status == 'CAPTURED' and not tx.is_today) or tx.status == 'PARTIALLY_REFUNDED' %}
                          <button type="button" class="btn btn-info btn-xs btn-full-refund"
                            data-tx="{{ tx.id }}">
                            <i class="fa fa-undo"></i> {{ button_full_refund }}
                            ({{ tx.remaining_refund }} {{ tx.currency }})
                          </button>
                          <button type="button" class="btn btn-warning btn-xs btn-partial-refund"
                            data-tx="{{ tx.id }}" data-max="{{ tx.remaining_refund }}">
                            <i class="fa fa-pencil"></i> {{ button_partial_refund }}
                          </button>

                          {# Partial refund amount input #}
                          <div class="partial-form partial-refund-form-{{ tx.id }}" style="display:none;margin-top:6px;">
                            <div class="input-group input-group-sm">
                              <input type="number" step="0.01" min="0.01" max="{{ tx.remaining_refund }}"
                                class="form-control partial-amount" placeholder="{{ text_enter_amount }}" style="width:110px;">
                              <span class="input-group-btn">
                                <button type="button" class="btn btn-warning btn-sm btn-partial-refund-confirm"
                                  data-tx="{{ tx.id }}">{{ button_confirm }}</button>
                                <button type="button" class="btn btn-default btn-sm btn-partial-cancel"
                                  data-target=".partial-refund-form-{{ tx.id }}">{{ button_cancel }}</button>
                              </span>
                            </div>
                          </div>
                        {% endif %}

                        {# No actions for terminal statuses #}
                        {% if tx.status not in ['AUTHORIZED', 'PARTIALLY_CAPTURED', 'CAPTURED', 'PARTIALLY_REFUNDED'] %}
                          <span class="text-muted">—</span>
                        {% endif %}

                      {% else %}
                        <span class="text-muted">—</span>
                      {% endif %}

                    </td>
                  </tr>

                  {# Secondary logs accordion row #}
                  {% if tx.logs %}
                    <tr class="bg-info">
                      <td colspan="9" style="padding:0;">
                        <div style="padding:10px 20px;">
                          <strong><i class="fa fa-history"></i> {{ text_logs }}</strong>
                          <table class="table table-condensed table-bordered" style="margin-top:6px;margin-bottom:0;background:#fff;">
                            <thead>
                              <tr>
                                <th>{{ column_action }}</th>
                                <th>{{ column_log_amount }}</th>
                                <th>{{ column_log_status }}</th>
                                <th>{{ column_log_date }}</th>
                              </tr>
                            </thead>
                            <tbody>
                              {% for log in tx.logs %}
                                <tr>
                                  <td><code>{{ log.action }}</code></td>
                                  <td>{{ log.amount }}</td>
                                  <td>
                                    <span class="label label-{{ log.status == 'SUCCESS' ? 'success' : 'danger' }}">
                                      {{ log.status }}
                                    </span>
                                  </td>
                                  <td>{{ log.created_at }}</td>
                                </tr>
                              {% endfor %}
                            </tbody>
                          </table>
                        </div>
                      </td>
                    </tr>
                  {% endif %}

                {% endfor %}
              </tbody>
            </table>
          </div>

          {# Pagination #}
          {% if pages > 1 %}
            <div class="text-center">
              <ul class="pagination">
                {% for p in 1..pages %}
                  <li class="{{ p == page ? 'active' : '' }}">
                    <a href="{{ index_url }}{% if filter_order_id %}&order_id={{ filter_order_id }}{% endif %}&page={{ p }}">{{ p }}</a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

        {% else %}
          <p class="text-muted">{{ text_no_results }}</p>
        {% endif %}
      </div>
    </div>

  </div>{# /container-fluid #}
</div>{# /content #}

{# Toast notification #}
<div id="cardlink-toast" style="display:none;position:fixed;bottom:20px;right:20px;z-index:9999;min-width:260px;" class="alert"></div>

<script>
(function($) {

    function showToast(msg, type) {
        var $t = $('#cardlink-toast');
        $t.removeClass('alert-success alert-danger alert-info')
          .addClass('alert-' + (type || 'info'))
          .html(msg)
          .fadeIn();
        setTimeout(function(){ $t.fadeOut(); }, 4000);
    }

    function ajaxAction(url, data, $row, callback) {
        var $btns = $row.find('button');
        $btns.prop('disabled', true);

        $.ajax({
            url: url,
            type: 'POST',
            dataType: 'json',
            data: data,
            success: function(resp) {
                if (resp.success) {
                    showToast(resp.message, 'success');
                    if (resp.new_status) {
                        setTimeout(function(){ location.reload(); }, 1200);
                    }
                } else {
                    showToast(resp.error || 'Error', 'danger');
                    $btns.prop('disabled', false);
                }
                if (callback) callback(resp);
            },
            error: function() {
                showToast('Network error', 'danger');
                $btns.prop('disabled', false);
            }
        });
    }

    var userToken  = '{{ user_token }}';
    var captureUrl = 'index.php?route=extension/payment/cardlink_transactions/capture&user_token=' + userToken;
    var voidUrl    = 'index.php?route=extension/payment/cardlink_transactions/voidTx&user_token=' + userToken;
    var refundUrl  = 'index.php?route=extension/payment/cardlink_transactions/refund&user_token=' + userToken;

    // Full Capture (remaining amount)
    $(document).on('click', '.btn-capture', function() {
        if (!confirm('Capture the remaining amount?')) return;
        var $row = $(this).closest('tr');
        ajaxAction(captureUrl, {
            transaction_id: $(this).data('tx')
        }, $row);
    });

    // Show partial capture form
    $(document).on('click', '.btn-partial-capture', function() {
        var id  = $(this).data('tx');
        var max = $(this).data('max');
        var $form = $('.partial-capture-form-' + id);
        $form.find('.partial-amount').attr('max', max);
        $form.toggle();
    });

    // Confirm partial capture
    $(document).on('click', '.btn-partial-capture-confirm', function() {
        var $form = $(this).closest('.partial-form');
        var amount = $form.find('.partial-amount').val();
        if (!amount || parseFloat(amount) <= 0) {
            alert('Please enter a valid amount.');
            return;
        }
        var $row = $(this).closest('tr');
        ajaxAction(captureUrl, {
            transaction_id: $(this).data('tx'),
            amount: amount
        }, $row);
    });

    // Void (AUTHORIZED preauth OR same-day CAPTURED)
    $(document).on('click', '.btn-void', function() {
        var msg = $(this).data('confirm') === 'void-captured'
            ? 'Cancel (void) this payment? This is only possible on the same day.'
            : 'Void (reverse) this pre-authorized transaction?';
        if (!confirm(msg)) return;
        var $row = $(this).closest('tr');
        ajaxAction(voidUrl, {
            transaction_id: $(this).data('tx')
        }, $row);
    });

    // Full Refund (remaining refundable amount)
    $(document).on('click', '.btn-full-refund', function() {
        if (!confirm('Process a refund of the remaining amount?')) return;
        var $row = $(this).closest('tr');
        ajaxAction(refundUrl, {
            transaction_id: $(this).data('tx'),
            type: 'full'
        }, $row);
    });

    // Show partial refund form
    $(document).on('click', '.btn-partial-refund', function() {
        var id  = $(this).data('tx');
        var max = $(this).data('max');
        var $form = $('.partial-refund-form-' + id);
        $form.find('.partial-amount').attr('max', max);
        $form.toggle();
    });

    // Confirm partial refund
    $(document).on('click', '.btn-partial-refund-confirm', function() {
        var $form  = $(this).closest('.partial-form');
        var amount = $form.find('.partial-amount').val();
        if (!amount || parseFloat(amount) <= 0) {
            alert('Please enter a valid amount.');
            return;
        }
        var $row = $(this).closest('tr');
        ajaxAction(refundUrl, {
            transaction_id: $(this).data('tx'),
            type: 'partial',
            amount: amount
        }, $row);
    });

    // Cancel partial form
    $(document).on('click', '.btn-partial-cancel', function() {
        var target = $(this).data('target');
        $(target).hide();
    });

})(jQuery);
</script>

{{ footer }}
