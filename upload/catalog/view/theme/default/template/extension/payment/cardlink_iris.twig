<div id="cardlink-container" align="right">

  <div class="buttons">
    <div class="pull-right">
      <button id="cardlink-pay-btn" class="btn btn-primary">{{ button_confirm }}</button>
    </div>
  </div>

</div>

{% if use_iframe %}
  <div id="cardlink-iframe-modal" class="cardlink-modal">
    <div class="cardlink-modal__backdrop"></div>
    <div class="cardlink-modal__box">
      <button id="cardlink-modal-close" class="cardlink-modal__close">×</button>

      <iframe
        id="payment_iframe"
        name="payment_iframe"
        width="100%"
        height="850"
        frameborder="0">
      </iframe>
    </div>
  </div>
{% endif %}

<script>
$(function(){

  $('#cardlink-pay-btn').on('click', function(e){
      e.preventDefault();

      $.ajax({
          url: 'index.php?route=extension/payment/cardlink_iris/confirm',
          type: 'post',
          dataType: 'json',
          success: function(json){

              if (!json || !json.action) {
                  alert('Payment error');
                  return;
              }

              // if iframe
              if (json.iframe == '1') {

                  // show modal
                  $('#cardlink-iframe-modal').fadeIn();

                  var form = $('<form>', {
                      method: 'post',
                      action: json.action,
                      target: 'payment_iframe'
                  });

                  form.append($('<input>', {
                      type: 'hidden',
                      name: 'use_iframe',
                      value: '1'
                  }));

                  $.each(json, function(key, value){
                      if (key === 'action' || key === 'iframe') return;
                      form.append($('<input>', {
                          type: 'hidden',
                          name: key,
                          value: value
                      }));
                  });

                  $('body').append(form);
                  form.submit();
              }
              else {
                  // redirect
                  var form = $('<form>', {
                      method: 'post',
                      action: json.action
                  });

                  $.each(json, function(key, value){
                      if (key === 'action' || key === 'iframe') return;
                      form.append($('<input>', {
                          type: 'hidden',
                          name: key,
                          value: value
                      }));
                  });

                  $('body').append(form);
                  form.submit();
              }
          }
      });
  });

  // close modal
  $('#cardlink-modal-close, .cardlink-modal__backdrop').on('click', function(){
      $('#cardlink-iframe-modal').fadeOut();
  });

  // listen for callback message
  window.addEventListener('message', function(event) {
    if (event.data && event.data.action === 'cardlink_close_iframe') {
      $('#cardlink-iframe-modal').fadeOut();

      if (event.data.status === 'success') {
        window.location.href = 'index.php?route=checkout/success';
      } else {
        window.location.href = 'index.php?route=checkout/checkout';
      }
    }
  });

});
</script>

<style>
.cardlink-modal {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 9999;
}

.cardlink-modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.6);
}

.cardlink-modal__box {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 95%;
  max-width: 900px;
  height: 90%;
  transform: translate(-50%, -50%);
  background: #fff;
  border-radius: 10px;
  overflow: hidden;
}

.cardlink-modal__close {
  position: absolute;
  top: 10px;
  right: 15px;
  background: transparent;
  border: none;
  font-size: 30px;
  cursor: pointer;
  z-index: 10;
}

</style>